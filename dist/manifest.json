{
  "manifest_version": 3,
  "name": "Shopee Thống Kê Chi Tiêu",
  "version": "2.0.0",
  "description": "Xem thống kê chi tiêu trên Shopee theo thời gian và theo năm - Built with TypeScript & React",
  "author": "Dinh Plus",
  "homepage_url": "https://github.com/dinhplus/shopee-stats-extension",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://shopee.vn/*"
  ],
  "action": {
    "default_popup": "src/pages/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Shopee Thống Kê"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
